---
import MainLayout from "../../layouts/MainLayout.astro";
import { Icon } from "astro-icon/components";

// Los 10 departamentos oficiales de Ayala
const tramitesDirectos = [
  {
    name: "Asuntos Migratorios",
    icon: "mdi:passport",
    href: "/tramites/migratorios",
  },
  {
    name: "Catastro",
    icon: "mdi:map-marker-distance",
    href: "/tramites/catastro",
  },
  { name: "Bomberos", icon: "mdi:fire-truck", href: "/tramites/bomberos" },
  {
    name: "Dirección de Salud",
    icon: "mdi:medical-bag",
    href: "/tramites/salud",
  },
  {
    name: "Impuesto Predial",
    icon: "mdi:home-city-outline",
    href: "/tramites/predial",
  },
  { name: "Juzgado de Paz", icon: "mdi:gavel", href: "/tramites/juzgado" },
  {
    name: "Licencias y Reglamentos",
    icon: "mdi:file-certificate",
    href: "/tramites/licencias",
  },
  {
    name: "Registro Civil",
    icon: "mdi:account-details",
    href: "/tramites/registro-civil",
  },
  {
    name: "Desarrollo Agropecuario",
    icon: "mdi:sprout",
    href: "/tramites/agropecuario",
  },
  {
    name: "Dirección de Gobierno",
    icon: "mdi:office-building",
    href: "/tramites/gobierno",
  },
];
---

<MainLayout title="Trámites y Servicios | Gobierno de Ayala">
  <section class="relative bg-[#8B1A2B] pt-16 pb-32 overflow-hidden">
    <div
      class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center"
    >
      <nav class="flex justify-center mb-8">
        <ol
          class="inline-flex items-center space-x-2 bg-white/10 backdrop-blur-md px-5 py-2 rounded-full border border-white/20"
        >
          <li>
            <a
              href="/"
              class="flex items-center text-xs font-bold text-white/90 hover:text-white transition-colors uppercase tracking-widest"
            >
              <Icon name="mdi:home" class="w-4 h-4 mr-2" />
              Inicio
            </a>
          </li>
          <Icon name="mdi:chevron-right" class="w-4 h-4 text-white/40" />
          <li class="text-xs font-bold text-white uppercase tracking-widest">
            Trámites
          </li>
        </ol>
      </nav>

      <h1
        class="text-4xl md:text-6xl font-black text-white mb-6 tracking-tighter uppercase"
      >
        Trámites y <span class="text-white/60">Servicios</span>
      </h1>
      <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto font-medium">
        Selecciona el área o departamento donde deseas realizar tu gestión.
      </p>
    </div>

    <div
      class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-0"
    >
      <svg
        class="relative block w-full h-[80px]"
        viewBox="0 0 1200 120"
        preserveAspectRatio="none"
      >
        <path
          d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,130.61,200.7,125.82,242.45,123,283.47,113.68,321.39,56.44Z"
          fill="#f9fafb"></path>
      </svg>
    </div>
  </section>

  <section class="bg-gray-50 pb-24 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-16 relative z-20">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {
          tramitesDirectos.map((item) => (
            <a
              href={item.href}
              class="group bg-white rounded-[2rem] p-8 shadow-lg shadow-gray-200/40 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 border border-gray-100 flex flex-col items-center text-center"
            >
              <div class="w-16 h-16 bg-gray-50 group-hover:bg-[#8B1A2B] rounded-2xl flex items-center justify-center mb-6 transition-all duration-500 shadow-inner group-hover:shadow-[#8B1A2B]/20">
                <Icon
                  name={item.icon}
                  class="w-8 h-8 text-[#8B1A2B] group-hover:text-white transition-colors duration-500"
                />
              </div>

              <h2 class="text-sm font-extrabold text-gray-900 group-hover:text-[#8B1A2B] transition-colors leading-tight uppercase tracking-tight">
                {item.name}
              </h2>

              <div class="mt-4 flex items-center justify-center w-full overflow-hidden h-6">
                <Icon
                  name="mdi:arrow-right"
                  class="w-5 h-5 text-[#8B1A2B] transform -translate-x-8 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-300"
                />
              </div>
            </a>
          ))
        }
      </div>

      <div class="mt-16 text-center">
        <p class="text-gray-400 text-sm italic">
          ¿No encuentras lo que buscas? Acude a las oficinas del H. Ayuntamiento
          para atención personalizada.
        </p>
      </div>
    </div>
  </section>
</MainLayout>
