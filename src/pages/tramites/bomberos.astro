---
import MainLayout from "../../layouts/MainLayout.astro";
import { Icon } from "astro-icon/components";

const documentos = [
  {
    nombre: "Servicio de Fuga de Gas (C. Amarillo)",
    file: "SERVICIO DE FUGA DE GAS (C.AMARILLO).docx",
  },
  {
    nombre: "Servicio de Fuga de Gas (Rojo)",
    file: "SERVICIO DE FUGA DE GAS (ROJO).docx",
  },
  {
    nombre: "Servicio de Incendio en Casa Habitación",
    file: "SERVICIO DE INCENDIO EN CASA HABITACION.docx",
  },
  {
    nombre: "Servicio de Incendio en Fábrica",
    file: "SERVICIO DE INCENDIO EN FABRICA.docx",
  },
  {
    nombre: "Servicio de Quema de Pastizal",
    file: "SERVICIO DE QUEMA DE PASTIZAL.docx",
  },
  {
    nombre: "Servicio de Retiro de Abejas",
    file: "SERVICIO DE RETIRO DE ABEJAS.docx",
  },
];

const folderPath = "/BOMBEROS/";
---

<MainLayout title="Heroico Cuerpo de Bomberos | Gobierno de Ayala">
  <section class="relative bg-[#8B1A2B] pt-16 pb-32 overflow-hidden">
    <div
      class="absolute top-0 right-0 -translate-y-1/4 translate-x-1/4 w-96 h-96 bg-red-500/10 rounded-full blur-3xl"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 relative z-10 text-center">
      <a
        href="/tramites"
        class="inline-flex items-center text-white/60 hover:text-white mb-8 text-xs font-bold uppercase tracking-widest transition-colors group"
      >
        <Icon
          name="mdi:arrow-left"
          class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform"
        />
        Volver a Trámites
      </a>
      <h1
        class="text-4xl md:text-6xl font-black text-white uppercase tracking-tighter mb-6"
      >
        Heroico Cuerpo de <span class="text-white/50">Bomberos</span>
      </h1>
      <p class="text-white/80 max-w-2xl mx-auto text-lg font-medium">
        Guías de actuación y formatos de reporte para servicios de emergencia y
        prevención en el municipio.
      </p>
    </div>
    <div
      class="absolute bottom-0 w-full h-16 bg-gray-50"
      style="clip-path: polygon(0 100%, 100% 100%, 100% 0);"
    >
    </div>
  </section>

  <section class="bg-gray-50 pb-24 -mt-12">
    <div class="max-w-7xl mx-auto px-4 relative z-20">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          documentos.map((doc) => (
            <div class="group bg-white rounded-[2.5rem] p-8 shadow-sm border border-gray-100 hover:shadow-2xl hover:border-red-500/10 transition-all duration-500 flex flex-col justify-between overflow-hidden relative">
              <div class="absolute top-0 left-0 w-full h-1 bg-red-600 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left" />

              <div>
                <div class="flex items-start justify-between mb-6">
                  <div class="p-4 bg-red-50 rounded-2xl group-hover:bg-red-600 transition-colors duration-500">
                    <Icon
                      name="mdi:fire-truck"
                      class="w-10 h-10 text-red-600 group-hover:text-white transition-colors"
                    />
                  </div>
                  <span class="text-[10px] font-black text-gray-400 uppercase tracking-[0.15em] bg-gray-100 px-3 py-1.5 rounded-lg">
                    DOCX / 525 KB
                  </span>
                </div>
                <h3 class="text-gray-900 font-bold text-xl leading-tight mb-8 group-hover:text-red-600 transition-colors">
                  {doc.nombre}
                </h3>
              </div>

              <a
                href={`${folderPath}${doc.file}`}
                download
                class="w-full inline-flex items-center justify-center gap-3 bg-gray-900 text-white font-bold py-4 px-6 rounded-2xl hover:bg-red-700 transition-all active:scale-95 shadow-lg shadow-black/10"
              >
                <Icon name="mdi:download" class="w-5 h-5" />
                DESCARGAR REPORTE
              </a>
            </div>
          ))
        }
      </div>

      <div
        class="mt-16 bg-gradient-to-r from-red-700 to-[#8B1A2B] rounded-[3rem] p-10 md:p-14 text-white flex flex-col md:flex-row items-center gap-10 shadow-2xl shadow-red-900/20 border border-white/5 relative overflow-hidden"
      >
        <div
          class="absolute -right-10 -bottom-10 w-64 h-64 bg-white/5 rounded-full blur-3xl"
        >
        </div>

        <div class="bg-white/10 p-6 rounded-3xl backdrop-blur-md animate-pulse">
          <Icon name="mdi:phone-alert" class="w-14 h-14 text-white" />
        </div>

        <div class="text-center md:text-left relative z-10">
          <h4 class="text-3xl font-black mb-3 text-white">
            ¿Es una emergencia real?
          </h4>
          <p class="text-white/80 text-lg font-medium max-w-xl">
            Para atención inmediata de incendios, fugas o rescates, llama
            directamente al **911** o al número de Protección Civil local.
          </p>
        </div>

        <div class="md:ml-auto relative z-10">
          <a
            href="tel:911"
            class="bg-white text-red-700 font-black px-10 py-5 rounded-2xl hover:bg-gray-50 transition-all hover:-translate-y-1 active:scale-95 shadow-xl uppercase text-sm tracking-widest flex items-center gap-3"
          >
            <Icon name="mdi:phone" class="w-5 h-5" />
            Llamar ahora
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
