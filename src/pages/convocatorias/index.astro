---
import MainLayout from "../../layouts/MainLayout.astro";
import { Icon } from "astro-icon/components";

const convocatorias = [
  {
    titulo: "Convocatoria a Elección de Autoridades Auxiliares 2025",
    descripcion:
      "Bases y requisitos para el proceso de elección de ayudantes municipales del municipio de Ayala.",
    tipo: "pdf",
    enlace: "/CONVOCATORIAS/CONVOCATORIA-AYUDANTES-2025.pdf",
    icono: "mdi:account-tie-outline",
    size: "461 KB",
  },
  {
    titulo: "Calendario de los Foros de Consulta Ciudadana 2025",
    descripcion:
      "Consulta las fechas, horarios y sedes de las mesas de trabajo para el Plan de Desarrollo Municipal.",
    tipo: "enlace",
    enlace: "/convocatorias/calendario-foros",
    icono: "mdi:calendar-clock",
    badge: "Evento",
  },
  {
    titulo: "Registro o Renovación de Proveedores 2025",
    descripcion:
      "Documentación necesaria para la inscripción o actualización en el padrón de proveedores del ejercicio 2025.",
    tipo: "pdf",
    enlace:
      "/CONVOCATORIAS/CONVOCATORIA-PARA-INSCRIPCION-O-RENOVACION-DE-PROVEEDORES-2025-AYALA-MORELOS.pdf",
    icono: "mdi:file-certificate-outline",
    size: "635 KB",
  },
  {
    titulo: "Registro o Renovación de Proveedores 2026",
    descripcion:
      "Lineamientos y bases para el registro de proveedores correspondientes al ejercicio fiscal 2026.",
    tipo: "pdf",
    enlace:
      "/CONVOCATORIAS/CONVOCATORIA-PARA-INSCRIPCION-O-RENOVACION-DE-PROVEEDORES-2026-AYALA-MORELOS.pdf",
    icono: "mdi:file-document-edit-outline",
    size: "636 KB",
  },
];
---

<MainLayout title="Convocatorias Vigentes | Gobierno de Ayala">
  <section class="relative bg-[#8B1A2B] pt-20 pb-40 overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-full opacity-10">
      <Icon
        name="mdi:bullhorn-variant-outline"
        class="absolute -top-10 -left-10 w-80 h-80 rotate-12"
      />
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 text-center">
      <nav class="flex justify-center mb-8">
        <ol
          class="inline-flex items-center space-x-2 bg-black/20 backdrop-blur-md px-5 py-2 rounded-full border border-white/10"
        >
          <li>
            <a
              href="/"
              class="text-xs font-bold text-white/70 hover:text-white uppercase tracking-widest transition-colors"
              >Inicio</a
            >
          </li>
          <Icon name="mdi:chevron-right" class="w-4 h-4 text-white/30" />
          <li class="text-xs font-bold text-white uppercase tracking-widest">
            Convocatorias
          </li>
        </ol>
      </nav>

      <h1
        class="text-4xl md:text-7xl font-black text-white mb-6 tracking-tighter uppercase leading-none"
      >
        Participación <span class="text-white/40 italic">Ciudadana</span> Ayala
      </h1>
      <p
        class="text-lg md:text-2xl text-white/80 max-w-3xl mx-auto font-medium"
      >
        Consulta los documentos oficiales, convocatorias y procesos vigentes
        para el desarrollo de nuestro municipio.
      </p>
    </div>

    <div
      class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-0"
    >
      <svg
        class="relative block w-full h-[100px]"
        viewBox="0 0 1200 120"
        preserveAspectRatio="none"
      >
        <path
          d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,130.61,200.7,125.82,242.45,123,283.47,113.68,321.39,56.44Z"
          fill="#f9fafb"></path>
      </svg>
    </div>
  </section>

  <section class="bg-gray-50 pb-32 -mt-20">
    <div class="max-w-7xl mx-auto px-4 relative z-20">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {
          convocatorias.map((item) => (
            <div class="group bg-white rounded-[3rem] p-8 md:p-10 shadow-xl shadow-gray-200/50 border border-gray-100 flex flex-col md:flex-row gap-8 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
              <div
                class={`flex-shrink-0 w-24 h-24 md:w-32 md:h-32 rounded-[2rem] flex items-center justify-center transition-all duration-500 ${item.tipo === "enlace" ? "bg-[#8B1A2B] text-white shadow-lg shadow-[#8B1A2B]/30" : "bg-gray-50 text-gray-400 group-hover:bg-[#8B1A2B]/5 group-hover:text-[#8B1A2B]"}`}
              >
                <Icon name={item.icono} class="w-12 h-12 md:w-16 md:h-16" />
              </div>

              <div class="flex-grow flex flex-col">
                <div class="flex items-center gap-3 mb-4">
                  <span
                    class={`px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest ${item.tipo === "enlace" ? "bg-amber-100 text-amber-700" : "bg-blue-100 text-blue-700"}`}
                  >
                    {item.badge || "PDF Oficial"}
                  </span>
                  {item.size && (
                    <span class="text-[10px] font-bold text-gray-400 uppercase tracking-tighter italic">
                      {item.size}
                    </span>
                  )}
                </div>

                <h2 class="text-xl md:text-2xl font-black text-gray-900 mb-3 group-hover:text-[#8B1A2B] transition-colors leading-tight">
                  {item.titulo}
                </h2>

                <p class="text-gray-500 text-sm md:text-base mb-6 flex-grow leading-relaxed">
                  {item.descripcion}
                </p>

                <div>
                  {item.tipo === "enlace" ? (
                    <a
                      href={item.enlace}
                      class="inline-flex items-center gap-3 bg-gray-900 text-white font-black px-8 py-4 rounded-2xl hover:bg-[#8B1A2B] transition-all active:scale-95 shadow-xl"
                    >
                      VER CALENDARIO
                      <Icon
                        name="mdi:arrow-right"
                        class="w-5 h-5 group-hover:translate-x-1 transition-transform"
                      />
                    </a>
                  ) : (
                    <a
                      href={item.enlace}
                      download
                      class="inline-flex items-center gap-3 border-2 border-gray-900 text-gray-900 font-black px-8 py-4 rounded-2xl hover:bg-gray-900 hover:text-white transition-all active:scale-95"
                    >
                      DESCARGAR PDF
                      <Icon name="mdi:download" class="w-5 h-5" />
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div
        class="mt-20 bg-white border-4 border-[#8B1A2B] rounded-[4rem] p-10 md:p-16 flex flex-col lg:flex-row items-center gap-10 shadow-2xl relative"
      >
        <div
          class="absolute -top-8 left-1/2 -translate-x-1/2 bg-[#8B1A2B] text-white px-8 py-2 rounded-full font-black text-xs uppercase tracking-[0.3em]"
        >
          Información
        </div>

        <div class="bg-gray-50 p-8 rounded-[2.5rem] text-[#8B1A2B]">
          <Icon name="mdi:information-outline" class="w-20 h-20" />
        </div>

        <div class="text-center lg:text-left flex-grow">
          <h3 class="text-3xl font-black text-gray-900 mb-4 tracking-tighter">
            ¿Necesitas más información?
          </h3>
          <p
            class="text-gray-500 text-lg max-w-2xl leading-relaxed font-medium"
          >
            Si tienes dudas sobre los requisitos de las convocatorias o los
            procesos de registro de proveedores, acércate a las oficinas del
            Ayuntamiento de Ayala.
          </p>
        </div>

        <div class="flex-shrink-0">
          <a
            href="/contacto"
            class="inline-flex items-center justify-center bg-[#8B1A2B] text-white font-black px-10 py-5 rounded-[2rem] hover:bg-gray-900 transition-all shadow-xl shadow-[#8B1A2B]/20"
          >
            CONTÁCTANOS
          </a>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
