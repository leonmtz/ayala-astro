---
import MainLayout from "../layouts/MainLayout.astro";
import { Icon } from "astro-icon/components";

const noticias = [
  {
    id: 1,
    etiqueta: "Comunicado Oficial",
    fecha: "07 Mar 2026",
    titulo:
      "El Presidente Municipal anuncia nueva fase del programa de pavimentación en el centro histórico.",
  },
  {
    id: 2,
    etiqueta: "Cultura",
    fecha: "05 Mar 2026",
    titulo:
      "Inauguración de la exposición fotográfica 'Raíces de Ayala' en la plaza cívica.",
  },
  {
    id: 3,
    etiqueta: "Protección Civil",
    fecha: "04 Mar 2026",
    titulo:
      "Nuevas unidades de emergencia se integran al parque vehicular del municipio.",
  },
  {
    id: 4,
    etiqueta: "Desarrollo Social",
    fecha: "02 Mar 2026",
    titulo:
      "Abre la nueva convocatoria para becas de transporte a estudiantes universitarios.",
  },
  {
    id: 5,
    etiqueta: "Desarrollo Social",
    fecha: "02 Mar 2026",
    titulo:
      "Abre la nueva convocatoria para becas de transporte a estudiantes universitarios.",
  },
];

const descubreItems = [
  {
    id: "historia",
    titulo: "Historia",
    descripcion:
      "Cuna del agrarismo y tierra de Zapata. Aquí comenzó la revolución del sur y se forjó el lema de 'Tierra y Libertad'. Nuestro municipio es pilar fundamental en la historia nacional. Explora los museos, monumentos y relatos que mantienen viva la llama de nuestros héroes y la identidad de nuestra gente.", // Texto largo para aprovechar el scroll
    imagen: "/DJI_0044.jpg",
    tamaño: "principal",
    icono: "mdi:book-open-page-variant",
    enlace: "/descubre/historia",
  },
  {
    id: "eventos",
    titulo: "Eventos",
    descripcion: "Cartelera y festividades.",
    imagen: "/DJI_0048.jpg",
    tamaño: "cuadro",
    icono: "mdi:calendar-star",
    enlace: "/descubre/eventos",
  },
  {
    id: "lugares",
    titulo: "Lugares",
    descripcion: "Rincones hermosos de Ayala.",
    imagen: "/_A743517.jpg",
    tamaño: "cuadro",
    icono: "mdi:camera",
    enlace: "/descubre/lugares",
  },
  {
    id: "tradicion",
    titulo: "Tradición",
    descripcion: "Nuestras costumbres, bailes y fiestas patronales.",
    imagen: "/_A743845.jpg",
    tamaño: "ancho",
    icono: "mdi:drama-masks",
    enlace: "/descubre/tradicion",
  },
  {
    id: "turismo",
    titulo: "Turismo",
    descripcion: "Balnearios y haciendas.",
    imagen: "/_A743535.jpg",
    tamaño: "cuadro",
    icono: "mdi:map-marker-radius",
    enlace: "/descubre/turismo",
  },
  {
    id: "gastronomia",
    titulo: "Gastronomía",
    descripcion: "Sabores únicos de la tierra.",
    imagen: "/DJI_0028.jpg",
    tamaño: "cuadro",
    icono: "mdi:silverware-fork-knife",
    enlace: "/descubre/gastronomia",
  },
];

// Grid exacto: 4 columnas x 3 filas
const getGridSpan = (tamaño: string) => {
  switch (tamaño) {
    case "principal":
      return "lg:col-span-2 lg:row-span-3 min-h-[400px] lg:min-h-0";
    case "ancho":
      return "lg:col-span-2 lg:row-span-1 min-h-[200px] lg:min-h-0";
    default:
      return "lg:col-span-1 lg:row-span-1 min-h-[200px] lg:min-h-0"; // 'cuadro'
  }
};

const fbInfo = {
  url: "https://www.facebook.com/H.AyuntamientodeAyala2025al2027/",
  nombre: "H. Ayuntamiento de Ayala", // Lo acorté un poco para que luzca mejor en el celular falso
  iframeUrl: "https://www.facebook.com/plugins/page.php?href=https%3A%2F%2Fwww.facebook.com%2FH.AyuntamientodeAyala2025al2027%2F&tabs=timeline&width=340&height=500&small_header=false&adapt_container_width=true&hide_cover=false&show_facepile=true&appId"
};
---

<MainLayout title="Inicio | Gobierno de Ayala">
  <section
    class="relative w-full h-[60vh] lg:h-[75vh] min-h-[500px] flex items-center overflow-hidden"
  >
    <img
      src="/hero-banner.webp"
      alt="Ayala Morelos"
      class="absolute inset-0 w-full h-full object-cover object-center z-0 scale-105 animate-slow-zoom"
    />

    <div
      class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/50 to-transparent z-10"
    >
    </div>

    <div class="relative z-20 w-full mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="max-w-2xl animate-fade-in-up">
        <p
          class="text-white/80 font-bold tracking-[0.2em] uppercase text-xs sm:text-sm mb-3"
        >
          Bienvenido a la página oficial del
        </p>

        <h1
          class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-4 drop-shadow-lg"
        >
          Gobierno de <span
            class="text-[#8B1A2B] bg-white px-3 py-1 rounded-lg inline-block mt-2 shadow-xl"
            >Ayala</span
          >
        </h1>

        <p
          class="text-xl md:text-2xl text-gray-200 font-light italic border-l-4 border-[#8B1A2B] pl-4 mb-8"
        >
          "La transformación es contigo"
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/tramites"
            class="flex items-center justify-center gap-2 bg-[#8B1A2B] hover:bg-red-900 text-white font-bold py-3 px-6 rounded-lg shadow-lg hover:shadow-[#8B1A2B]/50 transition-all duration-300 hover:-translate-y-1 group"
          >
            <Icon
              name="mdi:file-document-edit-outline"
              class="w-5 h-5 group-hover:scale-110 transition-transform"
            />
            Trámites y Servicios
          </a>
          <a
            href="/descubre"
            class="flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/30 text-white font-bold py-3 px-6 rounded-lg transition-all duration-300 hover:-translate-y-1"
          >
            Descubre Ayala
          </a>
        </div>
      </div>
    </div>
  </section>

  <div
    class="w-full h-12 sm:h-16 md:h-20 lg:h-24 bg-[url('/greca-ayala.webp')] bg-repeat-x bg-contain bg-center relative z-30 shadow-[0_-10px_20px_rgba(0,0,0,0.1)] -mt-1"
  >
  </div>

  <section class="relative w-full py-20 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">
        <div class="w-full lg:w-1/2 relative group">
          <div
            class="absolute -inset-4 md:-inset-5 bg-[#8B1A2B]/10 rounded-3xl transform rotate-3 transition-transform duration-500 group-hover:rotate-6"
          >
          </div>

          <div
            class="relative rounded-2xl overflow-hidden shadow-2xl transform transition-transform duration-500 group-hover:-translate-y-2"
          >
            <img
              src="/ayuntamiento.webp"
              alt="Ayuntamiento de Ayala"
              class="w-full h-auto object-cover aspect-[4/3] sm:aspect-[16/10] lg:aspect-[4/3] scale-100 group-hover:scale-105 transition-transform duration-700"
            />
            <div
              class="absolute inset-0 border border-black/5 rounded-2xl z-10"
            >
            </div>
          </div>
        </div>

        <div class="w-full lg:w-1/2 flex flex-col items-start">
          <span
            class="text-[#8B1A2B] font-bold tracking-widest uppercase text-xs sm:text-sm mb-2 flex items-center gap-2"
          >
            <span class="w-8 h-0.5 bg-[#8B1A2B] rounded-full"></span>
            Administración 2025-2027
          </span>

          <h2
            class="text-4xl sm:text-5xl font-extrabold text-gray-900 mb-6 relative pb-4"
          >
            GOBIERNO
            <span
              class="absolute bottom-0 left-0 w-24 h-1.5 bg-gradient-to-r from-[#8B1A2B] to-red-500 rounded-full"
            ></span>
          </h2>

          <p
            class="text-gray-600 text-base sm:text-lg leading-relaxed mb-8 text-justify sm:text-left"
          >
            Los verdaderos cambios nacen cuando se escuchan y entienden las
            necesidades de cada comunidad, cuando se trabaja de la mano
            gobierno-comunidad. En esta administración trabajaremos sin
            descanso, asegurando un cambio notorio en la manera de servir y de
            responder a las demandas de nuestro municipio.
          </p>

          <div class="flex flex-wrap gap-3 sm:gap-4">
            <a
              href="/gobierno/mas"
              class="flex items-center gap-2 bg-[#8B1A2B] text-white px-5 sm:px-6 py-2.5 sm:py-3 rounded-full font-semibold text-sm sm:text-base hover:bg-red-900 hover:shadow-lg hover:shadow-[#8B1A2B]/30 hover:-translate-y-1 transition-all duration-300 group"
            >
              <Icon
                name="mdi:information-variant"
                class="w-5 h-5 group-hover:rotate-12 transition-transform"
              />
              Ver Más
            </a>

            <a
              href="/gobierno/municipio"
              class="flex items-center gap-2 bg-[#8B1A2B] text-white px-5 sm:px-6 py-2.5 sm:py-3 rounded-full font-semibold text-sm sm:text-base hover:bg-red-900 hover:shadow-lg hover:shadow-[#8B1A2B]/30 hover:-translate-y-1 transition-all duration-300 group"
            >
              <Icon
                name="mdi:bank"
                class="w-5 h-5 group-hover:-rotate-12 transition-transform"
              />
              Municipio
            </a>

            <a
              href="/gobierno/cabildo"
              class="flex items-center gap-2 bg-[#8B1A2B] text-white px-5 sm:px-6 py-2.5 sm:py-3 rounded-full font-semibold text-sm sm:text-base hover:bg-red-900 hover:shadow-lg hover:shadow-[#8B1A2B]/30 hover:-translate-y-1 transition-all duration-300 group"
            >
              <Icon
                name="mdi:account-group"
                class="w-5 h-5 group-hover:scale-110 transition-transform"
              />
              Cabildo
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRAMITES Y SERVICIOS -->

  <section class="relative w-full py-20 bg-[#8B1A2B] overflow-hidden">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <div class="text-center mb-14 animate-fade-in-up">
        <span
          class="text-white/80 font-bold tracking-[0.2em] uppercase text-xs sm:text-sm mb-3 block"
        >
          Trámites en Línea y Presenciales
        </span>
        <h2
          class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white tracking-tight"
        >
          TRÁMITES Y SERVICIOS
        </h2>
        <div class="w-16 h-1.5 bg-white/30 mx-auto mt-6 rounded-full"></div>
      </div>

      <div
        class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-6"
      >
        <a
          href="/tramites/predial"
          class="group bg-white rounded-[2rem] p-6 lg:p-8 flex flex-col items-center justify-center text-center shadow-lg hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 h-full border border-white/10"
        >
          <div
            class="w-16 h-16 bg-gray-50 group-hover:bg-[#8B1A2B] rounded-2xl flex items-center justify-center mb-4 transition-colors duration-300 shadow-sm"
          >
            <Icon
              name="mdi:home-city-outline"
              class="w-8 h-8 text-[#8B1A2B] group-hover:text-white transition-colors duration-300"
            />
          </div>

          <h3
            class="text-gray-900 font-bold text-sm lg:text-base group-hover:text-[#8B1A2B] transition-colors leading-tight"
          >
            Predial
          </h3>

          <div
            class="h-6 mt-2 flex items-center justify-center w-full overflow-hidden"
          >
            <Icon
              name="mdi:arrow-right"
              class="w-6 h-6 text-[#8B1A2B] transform -translate-x-8 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-300 ease-out"
            />
          </div>
        </a>

        <a
          href="/tramites/licencias"
          class="group bg-white rounded-[2rem] p-6 lg:p-8 flex flex-col items-center justify-center text-center shadow-lg hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 h-full border border-white/10"
        >
          <div
            class="w-16 h-16 bg-gray-50 group-hover:bg-[#8B1A2B] rounded-2xl flex items-center justify-center mb-4 transition-colors duration-300 shadow-sm"
          >
            <Icon
              name="mdi:card-account-details-outline"
              class="w-8 h-8 text-[#8B1A2B] group-hover:text-white transition-colors duration-300"
            />
          </div>
          <h3
            class="text-gray-900 font-bold text-sm lg:text-base group-hover:text-[#8B1A2B] transition-colors leading-tight"
          >
            Licencias
          </h3>
          <div
            class="h-6 mt-2 flex items-center justify-center w-full overflow-hidden"
          >
            <Icon
              name="mdi:arrow-right"
              class="w-6 h-6 text-[#8B1A2B] transform -translate-x-8 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-300 ease-out"
            />
          </div>
        </a>

        <a
          href="/tramites/refrendos"
          class="group bg-white rounded-[2rem] p-6 lg:p-8 flex flex-col items-center justify-center text-center shadow-lg hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 h-full border border-white/10"
        >
          <div
            class="w-16 h-16 bg-gray-50 group-hover:bg-[#8B1A2B] rounded-2xl flex items-center justify-center mb-4 transition-colors duration-300 shadow-sm"
          >
            <Icon
              name="mdi:file-document-refresh-outline"
              class="w-8 h-8 text-[#8B1A2B] group-hover:text-white transition-colors duration-300"
            />
          </div>
          <h3
            class="text-gray-900 font-bold text-sm lg:text-base group-hover:text-[#8B1A2B] transition-colors leading-tight"
          >
            Refrendos
          </h3>
          <div
            class="h-6 mt-2 flex items-center justify-center w-full overflow-hidden"
          >
            <Icon
              name="mdi:arrow-right"
              class="w-6 h-6 text-[#8B1A2B] transform -translate-x-8 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-300 ease-out"
            />
          </div>
        </a>

        <a
          href="/tramites/actas"
          class="group bg-white rounded-[2rem] p-6 lg:p-8 flex flex-col items-center justify-center text-center shadow-lg hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 h-full border border-white/10"
        >
          <div
            class="w-16 h-16 bg-gray-50 group-hover:bg-[#8B1A2B] rounded-2xl flex items-center justify-center mb-4 transition-colors duration-300 shadow-sm"
          >
            <Icon
              name="mdi:file-certificate-outline"
              class="w-8 h-8 text-[#8B1A2B] group-hover:text-white transition-colors duration-300"
            />
          </div>
          <h3
            class="text-gray-900 font-bold text-sm lg:text-base group-hover:text-[#8B1A2B] transition-colors leading-tight"
          >
            Actas
          </h3>
          <div
            class="h-6 mt-2 flex items-center justify-center w-full overflow-hidden"
          >
            <Icon
              name="mdi:arrow-right"
              class="w-6 h-6 text-[#8B1A2B] transform -translate-x-8 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-300 ease-out"
            />
          </div>
        </a>

        <a
          href="/tramites/apoyos"
          class="group bg-white rounded-[2rem] p-6 lg:p-8 flex flex-col items-center justify-center text-center shadow-lg hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 h-full border border-white/10"
        >
          <div
            class="w-16 h-16 bg-gray-50 group-hover:bg-[#8B1A2B] rounded-2xl flex items-center justify-center mb-4 transition-colors duration-300 shadow-sm"
          >
            <Icon
              name="mdi:hand-heart-outline"
              class="w-8 h-8 text-[#8B1A2B] group-hover:text-white transition-colors duration-300"
            />
          </div>
          <h3
            class="text-gray-900 font-bold text-sm lg:text-base group-hover:text-[#8B1A2B] transition-colors leading-tight"
          >
            Apoyos Sociales
          </h3>
          <div
            class="h-6 mt-2 flex items-center justify-center w-full overflow-hidden"
          >
            <Icon
              name="mdi:arrow-right"
              class="w-6 h-6 text-[#8B1A2B] transform -translate-x-8 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-300 ease-out"
            />
          </div>
        </a>
      </div>

      <div class="mt-14 text-center">
        <a
          href="/tramites"
          class="inline-flex items-center gap-2 bg-white text-[#8B1A2B] font-bold px-8 py-3.5 rounded-full shadow-lg hover:shadow-2xl hover:shadow-black/20 hover:-translate-y-1 hover:bg-gray-50 transition-all duration-300 group"
        >
          Ver catálogo completo de trámites
          <Icon
            name="mdi:arrow-right"
            class="w-5 h-5 group-hover:translate-x-1 transition-transform"
          />
        </a>
      </div>
    </div>
  </section>

  <!-- prensa -->

  <section class="relative w-full py-24 bg-gray-50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div
        class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12"
      >
        <div>
          <span
            class="flex items-center gap-2 text-[#8B1A2B] font-bold tracking-widest uppercase text-sm mb-3"
          >
            <span class="w-8 h-0.5 bg-[#8B1A2B] rounded-full"></span>
            Sala de Prensa
          </span>
          <h2
            class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight"
          >
            ÚLTIMAS NOTICIAS
          </h2>
        </div>

        <a
          href="/prensa"
          class="inline-flex items-center gap-2 text-gray-600 hover:text-[#8B1A2B] font-semibold group transition-colors"
        >
          Ver todo el archivo
          <Icon
            name="mdi:arrow-right"
            class="w-5 h-5 group-hover:translate-x-1 transition-transform"
          />
        </a>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-fr"
      >
        {
          noticias.map((noticia, index) => (
            <a
              href={`/prensa/${noticia.id}`}
              class={`group relative p-8 sm:p-10 rounded-[2rem] flex flex-col justify-between overflow-hidden transition-all duration-500 shadow-sm hover:shadow-2xl hover:-translate-y-1 ${
                // Lógica de Astro: Si es la primera noticia (index 0), la hacemos gigante y guinda.
                // Si son las demás, son tarjetas blancas regulares.
                index === 0
                  ? "lg:col-span-2 bg-[#8B1A2B] text-white hover:shadow-[#8B1A2B]/40"
                  : "bg-white text-gray-900 border border-gray-100 hover:border-[#8B1A2B]/30"
              }`}
            >
              <Icon
                name="mdi:format-quote-close"
                class={`absolute -top-6 -right-6 w-40 h-40 transform rotate-12 opacity-[0.03] transition-transform duration-500 group-hover:scale-125 ${
                  index === 0 ? "text-white" : "text-[#8B1A2B]"
                }`}
              />

              <div class="relative z-10 flex flex-wrap items-center justify-between gap-4 mb-12">
                <span
                  class={`text-xs font-bold uppercase tracking-wider px-4 py-1.5 rounded-full backdrop-blur-md ${
                    index === 0
                      ? "bg-white/20 text-white"
                      : "bg-gray-100 text-[#8B1A2B] group-hover:bg-[#8B1A2B]/10"
                  }`}
                >
                  {noticia.etiqueta}
                </span>
                <span
                  class={`text-sm font-medium flex items-center gap-1.5 ${
                    index === 0 ? "text-white/80" : "text-gray-500"
                  }`}
                >
                  <Icon name="mdi:calendar-blank-outline" class="w-4 h-4" />
                  {noticia.fecha}
                </span>
              </div>

              <div class="relative z-10">
                <h3
                  class={`font-extrabold leading-tight mb-8 transition-colors ${
                    index === 0
                      ? "text-3xl sm:text-4xl lg:text-5xl"
                      : "text-xl sm:text-2xl group-hover:text-[#8B1A2B]"
                  }`}
                >
                  {noticia.titulo}
                </h3>

                <div class="flex items-center gap-2 font-semibold">
                  <span
                    class={`text-sm ${index === 0 ? "text-white/90" : "text-[#8B1A2B]"}`}
                  >
                    Leer artículo completo
                  </span>
                  <div
                    class={`w-8 h-8 rounded-full flex items-center justify-center transition-transform duration-300 group-hover:translate-x-2 ${
                      index === 0
                        ? "bg-white/20"
                        : "bg-gray-50 group-hover:bg-[#8B1A2B]/10"
                    }`}
                  >
                    <Icon name="mdi:arrow-top-right" class="w-4 h-4" />
                  </div>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="relative w-full py-24 bg-zinc-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div
        class="absolute top-0 right-0 w-[800px] h-[800px] bg-[#8B1A2B] rounded-full mix-blend-multiply filter blur-3xl -translate-y-1/2 translate-x-1/3"
      >
      </div>
      <div
        class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-red-800 rounded-full mix-blend-multiply filter blur-3xl translate-y-1/3 -translate-x-1/4"
      >
      </div>
    </div>

    <div
      class="max-w-[95%] xl:max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10"
    >
      <div
        class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16"
      >
        <div>
          <span
            class="flex items-center gap-2 text-[#8B1A2B] font-bold tracking-widest uppercase text-sm mb-3"
          >
            <span class="w-8 h-0.5 bg-[#8B1A2B] rounded-full"></span>
            Explora Nuestro Municipio
          </span>
          <h2
            class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight"
          >
            DESCUBRE <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-[#8B1A2B] to-red-500"
              >AYALA</span
            >
          </h2>
        </div>

        <a
          href="/descubre"
          class="inline-flex items-center gap-2 text-gray-400 hover:text-white font-semibold group transition-colors"
        >
          Ver todo el contenido
          <div
            class="w-10 h-10 rounded-full border border-gray-600 flex items-center justify-center group-hover:border-[#8B1A2B] group-hover:bg-[#8B1A2B] transition-all duration-300"
          >
            <Icon
              name="mdi:arrow-right"
              class="w-5 h-5 group-hover:translate-x-0.5 transition-transform"
            />
          </div>
        </a>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4 grid-flow-row-dense auto-rows-[250px] md:auto-rows-[300px]"
      >
        {
          descubreItems.map((item) => (
            <a
              href={item.enlace}
              class={`group relative rounded-3xl overflow-hidden shadow-xl hover:shadow-2xl hover:shadow-[#8B1A2B]/20 transition-all duration-500 flex items-end ${getGridSpan(item.tamaño)} bg-zinc-800`}
            >
              <img
                src={item.imagen}
                alt={item.titulo}
                class="absolute inset-0 w-full h-full object-cover object-center z-0 scale-100 group-hover:scale-110 opacity-70 group-hover:opacity-100 transition-all duration-700 ease-out"
                loading="lazy"
                onerror="this.style.display='none'"
              />

              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent z-10 group-hover:from-black/80 group-hover:via-black/20 transition-colors duration-500" />

              <div class="relative z-20 p-6 md:p-8 w-full transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500 ease-out">
                <div class="flex items-center gap-3 mb-2">
                  <div class="w-10 h-10 rounded-full bg-[#8B1A2B] flex items-center justify-center shadow-lg transform -translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 delay-100">
                    <Icon name={item.icono} class="w-5 h-5 text-white" />
                  </div>
                  <h3 class="text-2xl sm:text-3xl font-bold text-white drop-shadow-md">
                    {item.titulo}
                  </h3>
                </div>

                <div class="overflow-hidden">
                  <p class="text-gray-300 text-sm sm:text-base opacity-0 transform translate-y-8 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 delay-150 line-clamp-2">
                    {item.descripcion}
                  </p>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

<section class="relative w-full py-24 bg-white overflow-hidden">
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-24 -right-24 w-[500px] h-[500px] bg-[#8B1A2B]/5 rounded-full mix-blend-multiply filter blur-3xl opacity-80"></div>
    <div class="absolute bottom-0 -left-24 w-[600px] h-[600px] bg-gray-100 rounded-full mix-blend-multiply filter blur-3xl"></div>
  </div>

  <div class="max-w-[95%] xl:max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex flex-col lg:flex-row gap-16 items-center justify-between">
      
      <div class="w-full lg:w-1/2 flex flex-col items-center text-center lg:items-start lg:text-left order-2 lg:order-1">
        
        <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-[#8B1A2B]/10 text-[#8B1A2B] font-bold tracking-widest uppercase text-xs sm:text-sm mb-6 border border-[#8B1A2B]/20 shadow-sm">
          <Icon name="mdi:facebook" class="w-5 h-5" />
          Comunidad Oficial
        </div>
        
        <h2 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-gray-900 tracking-tight mb-6 leading-tight">
          SÍGUENOS EN <br class="hidden lg:block" />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#8B1A2B] to-red-600">NUESTRA RED</span>
        </h2>
        
        <p class="text-lg text-gray-600 mb-8 max-w-xl leading-relaxed">
          Mantente al día con las noticias más recientes, avisos importantes, transmisiones en vivo y todo el trabajo que estamos realizando en la administración 2025-2027. ¡Tu participación es clave para la transformación de Ayala!
        </p>

        <ul class="space-y-4 mb-10 w-full max-w-md">
          <li class="flex items-center gap-3 text-gray-700 font-medium">
            <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center shrink-0">
               <Icon name="mdi:check-bold" class="w-5 h-5 text-gray-700" />
            </div>
            Avisos de servicios y convocatorias
          </li>
          <li class="flex items-center gap-3 text-gray-700 font-medium">
            <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center shrink-0">
               <Icon name="mdi:video-outline" class="w-5 h-5 text-gray-700" />
            </div>
            Transmisiones en vivo de eventos y Cabildo
          </li>
          <li class="flex items-center gap-3 text-gray-700 font-medium">
            <div class="w-8 h-8 rounded-full bg-[#8B1A2B]/10 flex items-center justify-center shrink-0">
               <Icon name="mdi:account-group-outline" class="w-5 h-5 text-[#8B1A2B]" />
            </div>
            Atención ciudadana directa
          </li>
        </ul>

        <a 
          href={fbInfo.url} 
          target="_blank" 
          rel="noopener noreferrer"
          class="group relative inline-flex items-center justify-center px-8 py-4 font-bold text-white bg-[#8B1A2B] rounded-full overflow-hidden shadow-[0_10px_20px_rgba(139,26,43,0.3)] hover:shadow-[0_15px_25px_rgba(139,26,43,0.4)] hover:-translate-y-1 transition-all duration-300"
        >
          <span class="absolute inset-0 w-full h-full -mt-1 rounded-lg opacity-30 bg-gradient-to-b from-transparent via-transparent to-black"></span>
          <Icon name="mdi:thumb-up-outline" class="relative w-6 h-6 mr-3 group-hover:scale-110 group-hover:-rotate-12 transition-transform duration-300" />
          <span class="relative text-lg">Ir a la Página Oficial</span>
        </a>

      </div>

      <div class="w-full lg:w-1/2 flex justify-center order-1 lg:order-2">
        <div class="relative w-full max-w-[380px]">
          
          <div class="absolute top-0 right-0 -mr-8 -mt-8 w-24 h-24 bg-[#8B1A2B] rounded-full mix-blend-multiply filter blur-xl opacity-30 animate-pulse"></div>
          <div class="absolute bottom-0 left-0 -ml-8 -mb-8 w-32 h-32 bg-gray-300 rounded-full mix-blend-multiply filter blur-2xl opacity-40"></div>
          
          <div class="relative bg-white rounded-[2.5rem] shadow-[0_25px_50px_-12px_rgba(0,0,0,0.15)] border-[8px] border-gray-100 overflow-hidden transform transition-transform duration-700 hover:-translate-y-2">
            
            <div class="absolute top-0 inset-x-0 h-6 bg-gray-100 rounded-b-3xl w-1/2 mx-auto z-20"></div>

            <div class="w-full bg-gradient-to-r from-[#8B1A2B] to-[#6A1220] text-white px-4 py-3 pt-6 flex items-center justify-between relative z-10 shadow-md">
              <Icon name="mdi:arrow-left" class="w-6 h-6 opacity-80" />
              <span class="font-bold text-sm tracking-wide truncate max-w-[200px]">{fbInfo.nombre}</span>
              <Icon name="mdi:dots-vertical" class="w-6 h-6 opacity-80" />
            </div>

            <div class="bg-gray-50 flex justify-center w-full min-h-[500px]">
              <iframe 
                src={fbInfo.iframeUrl} 
                width="340" 
                height="500" 
                style="border:none;overflow:hidden" 
                scrolling="no" 
                frameborder="0" 
                allowfullscreen="true" 
                allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
                title="Facebook Feed Ayuntamiento de Ayala"
                class="bg-white"
              ></iframe>
            </div>

            <div class="absolute bottom-0 inset-x-0 h-14 bg-white border-t border-gray-100 flex items-center justify-around px-4 z-10">
              <Icon name="mdi:home" class="w-7 h-7 text-[#8B1A2B]" />
              <Icon name="mdi:account-group" class="w-7 h-7 text-gray-300 hover:text-gray-500 transition-colors" />
              <div class="w-12 h-12 bg-gray-50 rounded-full flex items-center justify-center -mt-6 shadow-sm border-4 border-white">
                <Icon name="mdi:facebook" class="w-6 h-6 text-[#8B1A2B]" />
              </div>
              <Icon name="mdi:bell-outline" class="w-7 h-7 text-gray-300 hover:text-gray-500 transition-colors" />
              <Icon name="mdi:menu" class="w-7 h-7 text-gray-300 hover:text-gray-500 transition-colors" />
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</section>
</MainLayout>

<style>
  /* Animación para que el texto entre suavemente desde abajo */
  .animate-fade-in-up {
    animation: fadeInUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Animación para que la imagen de fondo haga un zoom IN muy lento (Efecto Ken Burns) */
  .animate-slow-zoom {
    animation: slowZoom 20s ease-in-out infinite alternate;
  }

  @keyframes fadeInUp {
    0% {
      opacity: 0;
      transform: translateY(40px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slowZoom {
    0% {
      transform: scale(1.02);
    }
    100% {
      transform: scale(1.1);
    }
  }
</style>
