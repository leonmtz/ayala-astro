---
import MainLayout from "../layouts/MainLayout.astro";
import { Icon } from "astro-icon/components";
---

<MainLayout title="404 - Página no encontrada | Gobierno de Ayala">
  <section
    class="min-h-[calc(100vh-220px)] flex items-center justify-center bg-gray-50 px-4 py-24 md:py-32 relative overflow-hidden"
  >
    <div
      class="absolute top-0 left-0 w-full h-full opacity-[0.03] pointer-events-none"
    >
      <Icon
        name="mdi:map-marker-question-outline"
        class="absolute -top-20 -right-20 w-[300px] h-[300px] md:w-[500px] md:h-[500px] rotate-12"
      />
      <Icon
        name="mdi:magnify-remove-outline"
        class="absolute -bottom-20 -left-20 w-[250px] h-[250px] md:w-[400px] md:h-[400px] -rotate-12"
      />
    </div>

    <div class="max-w-2xl w-full text-center relative z-10">
      <div
        class="inline-flex items-center justify-center w-28 h-28 md:w-44 md:h-44 bg-[#8B1A2B]/10 text-[#8B1A2B] rounded-[3rem] mb-8 md:mb-10 animate-bounce-slow"
      >
        <Icon
          name="mdi:alert-rhombus-outline"
          class="w-14 h-14 md:w-24 md:h-24"
        />
      </div>

      <h1
        class="text-6xl md:text-9xl font-black text-gray-900 tracking-tighter leading-none mb-4"
      >
        4<span class="text-[#8B1A2B]">0</span>4
      </h1>

      <h2
        class="text-2xl md:text-4xl font-black text-gray-800 uppercase tracking-tight mb-6 leading-tight"
      >
        ¡Híjole! Parece que te <br />
        <span class="text-[#8B1A2B] italic font-serif">perdiste</span> en Ayala.
      </h2>

      <p
        class="text-gray-500 text-lg md:text-xl font-medium mb-10 md:mb-12 max-w-lg mx-auto leading-relaxed"
      >
        La página que buscas no existe o fue movida. No te preocupes, siempre
        puedes volver al camino principal.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="w-full sm:w-auto bg-[#8B1A2B] text-white font-black px-10 py-5 rounded-2xl hover:bg-gray-900 transition-all shadow-xl shadow-[#8B1A2B]/20 active:scale-95 flex items-center justify-center gap-2"
        >
          <Icon name="mdi:home" class="w-5 h-5" />
          VOLVER AL INICIO
        </a>

        <a
          href="/contacto"
          class="w-full sm:w-auto border-2 border-gray-900 text-gray-900 font-black px-10 py-5 rounded-2xl hover:bg-gray-900 hover:text-white transition-all active:scale-95 flex items-center justify-center gap-2"
        >
          REPORTAR ERROR
          <Icon name="mdi:arrow-right" class="w-5 h-5" />
        </a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  @keyframes bounce-slow {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  .animate-bounce-slow {
    animation: bounce-slow 4s ease-in-out infinite;
  }
</style>
