---
import MainLayout from "../layouts/MainLayout.astro";
import { Icon } from "astro-icon/components";
---

<MainLayout title="En Construcción | Gobierno de Ayala">
  {/* Usamos 'style' nativo para forzar el espaciado y evitar que Tailwind lo ignore */}
  <section 
    class="relative w-full bg-gray-50 overflow-hidden px-4"
    style="min-height: 70vh; display: flex; align-items: center; justify-content: center; padding-top: 120px; padding-bottom: 120px;"
  >
    
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-10 right-10 w-[400px] h-[400px] bg-[#8B1A2B]/5 rounded-full mix-blend-multiply blur-3xl"></div>
      <div class="absolute bottom-10 left-10 w-[500px] h-[500px] bg-gray-200/50 rounded-full mix-blend-multiply blur-3xl"></div>
    </div>

    <div class="relative z-10 max-w-2xl mx-auto text-center w-full">
      
      <div class="w-24 h-24 mx-auto bg-white rounded-2xl flex items-center justify-center mb-10 shadow-sm border border-gray-100">
        <Icon name="mdi:tools" class="w-12 h-12 text-[#8B1A2B]" /> 
      </div>

      <span class="inline-block px-5 py-2 rounded-full bg-white text-[#8B1A2B] font-bold tracking-widest uppercase text-xs mb-8 border border-gray-100 shadow-sm">
        Aviso Importante
      </span>
      
      <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight mb-8">
        Sección en <br class="sm:hidden" />
        <span class="text-[#8B1A2B]">Mantenimiento</span>
      </h1>
      
      <p class="text-lg sm:text-xl text-gray-600 mb-12 leading-relaxed">
        El H. Ayuntamiento de Ayala 2025-2027 se encuentra trabajando en la integración de esta información para brindarle un servicio oportuno y transparente. Agradecemos su comprensión.
      </p>

      <a 
        href="/" 
        class="group inline-flex items-center justify-center gap-3 px-8 py-4 font-bold text-white bg-[#8B1A2B] rounded-full shadow-lg hover:shadow-xl hover:bg-red-900 hover:-translate-y-1 transition-all duration-300"
      >
        <Icon name="mdi:arrow-left" class="w-5 h-5 group-hover:-translate-x-1 transition-transform" />
        Regresar al Inicio
      </a>

    </div>
  </section>
</MainLayout>