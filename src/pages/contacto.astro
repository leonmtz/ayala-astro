---
import MainLayout from "../layouts/MainLayout.astro";
import { Icon } from "astro-icon/components";

const oficinas = [
  {
    nombre: "Presidencia Municipal",
    direccion: "Plaza Cívica Francisco Ayala Sn, Centro, 62700 Cd. Ayala, Mor.",
    telefono: "(735) 308 3548",
    horario: "Lunes a Viernes: 8:00 AM - 4:00 PM",
    icono: "mdi:bank-outline",
  },
  {
    nombre: "Seguridad Pública",
    direccion: "Carretera Ayala-Cuautla S/N, Cd. Ayala, Mor.",
    telefono: "(735) 354 0919",
    horario: "Emergencias: 24 Horas",
    icono: "mdi:shield-check-outline",
  },
  {
    nombre: "DIF Ayala",
    direccion: "Av. Constitución, Centro, Cd. Ayala, Mor.",
    telefono: "(735) 154 6112",
    horario: "Lunes a Viernes: 9:00 AM - 3:00 PM",
    icono: "mdi:account-heart-outline",
  },
];
---

<MainLayout title="Contacto | Gobierno de Ayala">
  <div class="h-24 md:h-32 lg:h-40 bg-[#8B1A2B]"></div>

  <section
    class="relative bg-[#8B1A2B] pb-24 md:pb-28 lg:pb-32 overflow-hidden"
  >
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <Icon
        name="mdi:message-draw"
        class="absolute -bottom-10 -left-10 w-96 h-96 text-white -rotate-12"
      />
    </div>

    <div
      class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center pb-8 md:pb-10"
    >
      <nav class="flex justify-center mb-8">
        <ol
          class="inline-flex items-center space-x-2 bg-black/20 px-5 py-2 rounded-full border border-white/10 backdrop-blur-md"
        >
          <li>
            <a
              href="/"
              class="flex items-center text-sm font-medium text-white/80 hover:text-white transition-colors"
            >
              <Icon name="mdi:home" class="w-4 h-4 mr-2" />
              Inicio
            </a>
          </li>
          <li>
            <div class="flex items-center">
              <Icon name="mdi:chevron-right" class="w-5 h-5 text-white/50" />
              <span
                class="ml-2 text-sm font-bold text-white tracking-widest uppercase"
                >Contacto</span
              >
            </div>
          </li>
        </ol>
      </nav>

      <h1
        class="text-5xl md:text-6xl lg:text-8xl font-extrabold text-white mb-6 tracking-tight uppercase animate-fade-in-up"
      >
        ESTAMOS PARA <span class="text-red-300">SERVIRTE</span>
      </h1>

      <p
        class="text-lg md:text-2xl text-white/90 max-w-3xl mx-auto font-light leading-relaxed"
      >
        Tu opinión y participación son fundamentales para la transformación de
        Ayala. <br class="hidden md:block" /> Ponte en contacto con nosotros.
      </p>
    </div>

    <div
      class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-0"
    >
      <svg
        class="relative block w-full h-[60px] md:h-[100px]"
        viewBox="0 0 1200 120"
        preserveAspectRatio="none"
      >
        <path
          d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.08,130.83,130.61,200.7,125.82,242.45,123,283.47,113.68,321.39,56.44Z"
          fill="#ffffff"></path>
      </svg>
    </div>
  </section>

  <section class="bg-white pt-10 md:pt-14 lg:pt-16 pb-24 relative z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
        <div class="lg:col-span-1 space-y-6">
          <div class="flex items-center gap-3 mb-8">
            <span class="w-2 h-10 bg-[#8B1A2B] rounded-full"></span>
            <h2 class="text-3xl font-extrabold text-gray-900 tracking-tight">
              Directorio <br />Principal
            </h2>
          </div>

          {
            oficinas.map((oficina) => (
              <div class="group bg-gray-50 p-6 rounded-[2.5rem] border border-gray-100 hover:bg-white hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
                <div class="flex items-start gap-5">
                  <div class="w-14 h-14 rounded-2xl bg-[#8B1A2B]/10 flex items-center justify-center group-hover:bg-[#8B1A2B] transition-colors duration-300">
                    <Icon
                      name={oficina.icono}
                      class="w-7 h-7 text-[#8B1A2B] group-hover:text-white"
                    />
                  </div>
                  <div class="flex-1">
                    <h3 class="font-bold text-gray-900 text-xl mb-2">
                      {oficina.nombre}
                    </h3>
                    <p class="text-gray-500 text-sm mb-4 leading-relaxed italic">
                      {oficina.direccion}
                    </p>
                    <div class="space-y-2">
                      <a
                        href={`tel:${oficina.telefono}`}
                        class="flex items-center gap-2 text-[#8B1A2B] font-extrabold text-base hover:underline transition-all"
                      >
                        <Icon name="mdi:phone" class="w-5 h-5" />
                        {oficina.telefono}
                      </a>
                      <p class="flex items-center gap-2 text-gray-400 text-xs font-semibold uppercase tracking-wider">
                        <Icon name="mdi:clock-outline" class="w-4 h-4" />
                        {oficina.horario}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <div class="lg:col-span-2 space-y-12">
          <div
            class="bg-white rounded-[3.5rem] p-8 md:p-14 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] border border-gray-50"
          >
            <div class="mb-12">
              <span
                class="text-[#8B1A2B] font-bold tracking-[0.2em] uppercase text-xs mb-3 block"
                >Comunicación Directa</span
              >
              <h2
                class="text-4xl font-extrabold text-gray-900 mb-4 tracking-tight"
              >
                Buzón Ciudadano
              </h2>
              <div class="w-12 h-1.5 bg-[#8B1A2B]/20 rounded-full"></div>
            </div>

            <form class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="space-y-3">
                <label
                  class="text-xs font-black text-gray-400 uppercase tracking-widest ml-1"
                  >Nombre Completo</label
                >
                <input
                  type="text"
                  placeholder="Ej. Leonardo Patricio"
                  class="w-full px-7 py-5 rounded-2xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-[#8B1A2B] focus:ring-0 outline-none transition-all duration-300 font-medium"
                />
              </div>
              <div class="space-y-3">
                <label
                  class="text-xs font-black text-gray-400 uppercase tracking-widest ml-1"
                  >Correo Electrónico</label
                >
                <input
                  type="email"
                  placeholder="tu@correo.com"
                  class="w-full px-7 py-5 rounded-2xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-[#8B1A2B] focus:ring-0 outline-none transition-all duration-300 font-medium"
                />
              </div>
              <div class="md:col-span-2 space-y-3">
                <label
                  class="text-xs font-black text-gray-400 uppercase tracking-widest ml-1"
                  >Asunto / Dependencia</label
                >
                <div class="relative">
                  <select
                    class="w-full px-7 py-5 rounded-2xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-[#8B1A2B] outline-none transition-all appearance-none cursor-pointer font-medium"
                  >
                    <option>Atención Ciudadana</option>
                    <option>Servicios Públicos</option>
                    <option>Obras Públicas</option>
                    <option>Tesorería</option>
                  </select>
                  <Icon
                    name="mdi:chevron-down"
                    class="absolute right-6 top-1/2 -translate-y-1/2 w-6 h-6 text-gray-400 pointer-events-none"
                  />
                </div>
              </div>
              <div class="md:col-span-2 space-y-3">
                <label
                  class="text-xs font-black text-gray-400 uppercase tracking-widest ml-1"
                  >Mensaje</label
                >
                <textarea
                  rows="5"
                  placeholder="¿En qué podemos ayudarte hoy?"
                  class="w-full px-7 py-5 rounded-3xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-[#8B1A2B] outline-none transition-all resize-none font-medium"
                ></textarea>
              </div>
              <div class="md:col-span-2 pt-4">
                <button
                  class="w-full md:w-auto bg-[#8B1A2B] text-white px-12 py-5 rounded-2xl font-black text-lg shadow-xl shadow-[#8B1A2B]/30 hover:bg-red-900 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 flex items-center justify-center gap-4 group"
                >
                  ENVIAR REPORTE
                  <Icon
                    name="mdi:send-check"
                    class="w-6 h-6 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"
                  />
                </button>
              </div>
            </form>
          </div>

          <div
            class="rounded-[3.5rem] overflow-hidden shadow-2xl h-[500px] border-[12px] border-gray-50 relative group"
          >
            <div
              class="absolute top-6 left-6 z-10 bg-white/90 backdrop-blur px-4 py-2 rounded-xl shadow-lg border border-gray-100 hidden md:flex items-center gap-2"
            >
              <Icon
                name="mdi:map-marker-radius"
                class="w-5 h-5 text-[#8B1A2B]"
              />
              <span class="text-xs font-bold text-gray-900"
                >Ubicación Oficial</span
              >
            </div>
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3776.4382583857544!2d-98.916174!3d18.765107!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85ceeb0000000000%3A0x0!2zMTjCsDQ1JzU0LjQiTiA5OMKwNTQnNTguMiJX!5e0!3m2!1ses-419!2smx!4v1710000000000!5m2!1ses-419!2smx"
              class="w-full h-full grayscale-[0.3] group-hover:grayscale-0 transition-all duration-1000"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
            >
            </iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeInUp {
    0% {
      opacity: 0;
      transform: translateY(30px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  input::placeholder,
  textarea::placeholder {
    color: #9ca3af;
    font-weight: 400;
  }
</style>
