---
import { Icon } from "astro-icon/components";
---

<footer id="footer" class="bg-[#8B1A2B] text-white pt-12 pb-6 relative">
  <div class="w-full mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 mb-12"
    >
      <div class="flex flex-col gap-4">
        <img
          src="/Logo-blanco.png"
          class="h-20 w-auto object-contain mb-2 brightness-0 invert"
          alt="H. Ayuntamiento de Ayala"
        />

        <h3 class="text-lg font-bold">Ayuntamiento de Ayala Morelos</h3>
        <div
          class="flex items-start gap-3 text-white/90 hover:text-white transition-colors"
        >
          <Icon name="mdi:map-marker" class="w-5 h-5 mt-1 flex-shrink-0" />
          <p class="text-sm leading-relaxed">
            Plaza Cívica Francisco Ayala Sn, Centro,<br />
            62700 Cd. Ayala, Mor.
          </p>
        </div>
        <div
          class="flex items-center gap-3 text-white/90 hover:text-white transition-colors"
        >
          <Icon name="mdi:phone" class="w-5 h-5 flex-shrink-0" />
          <a href="tel:+527353083548" class="text-sm">(735) 308 3548</a>
        </div>
      </div>

      <div class="flex flex-col gap-4">
        <h3
          class="text-lg font-bold border-b border-white/20 pb-2 mb-2 inline-block"
        >
          Directorio
        </h3>

        <div class="space-y-5">
          <div>
            <p
              class="text-xs font-semibold text-white/60 uppercase tracking-wider mb-2"
            >
              Teléfonos de Emergencia
            </p>
            <div class="flex flex-col gap-2">
              <a
                href="tel:+527353540919"
                class="flex items-center gap-2 text-sm hover:text-gray-300 transition-colors group"
              >
                <Icon
                  name="mdi:alert-circle"
                  class="w-4 h-4 text-red-300 group-hover:text-white transition-colors"
                />
                (735) 354 0919
              </a>
              <a
                href="tel:+527351546112"
                class="flex items-center gap-2 text-sm hover:text-gray-300 transition-colors group"
              >
                <Icon
                  name="mdi:alert-circle"
                  class="w-4 h-4 text-red-300 group-hover:text-white transition-colors"
                />
                (735) 154 6112
              </a>
            </div>
          </div>

          <div class="pt-2">
            <a
              href="/transparencia"
              class="inline-flex items-center gap-2 text-sm font-semibold hover:text-gray-300 transition-colors group"
            >
              <Icon
                name="mdi:file-document-outline"
                class="w-5 h-5 group-hover:scale-110 transition-transform"
              />
              Portal de Transparencia
            </a>
          </div>
        </div>
      </div>

      <div
        class="flex flex-col gap-4 items-start md:items-center lg:items-start"
      >
        <h3
          class="text-lg font-bold border-b border-white/20 pb-2 mb-2 w-full text-left"
        >
          Denuncia Ciudadana
        </h3>

        <div
          class="bg-white p-3 rounded-xl shadow-lg hover:scale-105 transition-transform duration-300 group"
        >
          <img
            src="/qr-denuncia.png"
            alt="Código QR Denuncia Ciudadana"
            class="w-28 h-28 sm:w-32 sm:h-32 object-cover rounded-lg"
          />
        </div>
        <p class="text-xs text-white/80 mt-1 max-w-[200px]">
          Escanea este código para realizar tu reporte de forma rápida.
        </p>
      </div>

      <div class="flex flex-col gap-4 h-full">
        <h3 class="text-lg font-bold border-b border-white/20 pb-2 mb-2">
          Ubicación
        </h3>

        <div
          class="w-full h-40 sm:h-48 rounded-xl overflow-hidden shadow-lg border border-white/20 relative group"
        >
          <iframe
            src="https://maps.google.com/maps?q=Plaza+C%C3%ADvica+Francisco+Ayala+Sn,+Centro,+62700+Cdad.+Ayala,+Mor.&t=&z=16&ie=UTF8&iwloc=&output=embed"
            class="w-full h-full border-0 grayscale group-hover:grayscale-0 transition-all duration-500"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          >
          </iframe>
        </div>
      </div>
    </div>

    <div
      class="pt-6 border-t border-white/20 flex flex-col md:flex-row justify-between items-center gap-4"
    >
      <p class="text-xs text-white/60 text-center md:text-left">
        &copy; 2025-2027 H. Ayuntamiento Constitucional de Ayala, Morelos. Todos
        los derechos reservados.
      </p>

      <button
        onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
        aria-label="Volver arriba"
        class="bg-white/10 hover:bg-white text-white hover:text-[#8B1A2B] p-2.5 rounded-full transition-all duration-300 shadow-sm"
      >
        <Icon name="mdi:chevron-up" class="w-5 h-5" />
      </button>
    </div>
  </div>
</footer>
