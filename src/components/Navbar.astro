                CUENTA PÚBLICA 2024
              </a>

              <div
                class="group/sub relative px-5 py-2.5 text-xs xl:text-sm text-gray-700 font-bold hover:text-[#8B1A2B] hover:bg-gray-50 transition-colors border-b border-gray-50 flex justify-between items-center cursor-pointer"
              >
                <span>CUENTA PÚBLICA 2025</span>
                <Icon name="mdi:chevron-right" class="w-4 h-4" />

                <div
                  class="absolute left-full top-0 pl-2 opacity-0 invisible translate-x-2 transition-all duration-300 group-hover/sub:visible group-hover/sub:opacity-100 group-hover/sub:translate-x-0"
                >
                  <div
                    class="bg-white rounded-xl shadow-lg border border-gray-100 py-2 w-56"
                  >
                    <a
                      href="#"
                      class="block px-5 py-2 hover:bg-gray-50 hover:text-[#8B1A2B]"
                      >1ER TRIMESTRE 2025</a
                    >
                    <a
                      href="#"
                      class="block px-5 py-2 hover:bg-gray-50 hover:text-[#8B1A2B]"
                      >2DO TRIMESTRE 2025</a
                    >
                    <a
                      href="#"
                      class="block px-5 py-2 hover:bg-gray-50 hover:text-[#8B1A2B]"
                      >3ER TRIMESTRE 2025</a
                    >
                    <a
                      href="#"
                      class="block px-5 py-2 hover:bg-gray-50 hover:text-[#8B1A2B]"
                      >4TO TRIMESTRE 2025</a
                    >
                  </div>
                </div>
              </div>

              <div
                class="group/sub relative px-5 py-2.5 text-xs xl:text-sm text-gray-700 font-bold hover:text-[#8B1A2B] hover:bg-gray-50 transition-colors border-b border-gray-50 flex justify-between items-center cursor-pointer"
              >
                <span class="leading-tight"
                  >SISTEMA DE RECURSOS FEDERALES TRANSFERIDOS (SRFT)</span
                >
                <Icon name="mdi:chevron-right" class="w-4 h-4" />

                <div
                  class="absolute left-full top-0 pl-2 opacity-0 invisible translate-x-2 transition-all duration-300 group-hover/sub:visible group-hover/sub:opacity-100 group-hover/sub:translate-x-0"
                >
                  <div
                    class="bg-white rounded-xl shadow-lg border border-gray-100 py-2 w-48"
                  >
                    <div
                      class="group/nested relative px-5 py-2 hover:bg-gray-50 flex justify-between items-center"
                    >
                      <span>2025</span>
                      <Icon name="mdi:chevron-right" class="w-4 h-4" />
                      <div
                        class="absolute left-full top-0 pl-2 opacity-0 invisible translate-x-2 transition-all duration-300 group-hover/nested:visible group-hover/nested:opacity-100 group-hover/nested:translate-x-0"
                      >
                        <div
                          class="bg-white rounded-xl shadow-lg border border-gray-100 py-2 w-48"
                        >
                          <a href="#" class="block px-5 py-2 hover:bg-gray-50"
                            >1ER TRIMESTRE</a
                          >
                          <a href="#" class="block px-5 py-2 hover:bg-gray-50"
                            >2DO TRIMESTRE</a
                          >
                          <a href="#" class="block px-5 py-2 hover:bg-gray-50"
                            >3ER TRIMESTRE</a
                          >
                          <a href="#" class="block px-5 py-2 hover:bg-gray-50"
                            >4TO TRIMESTRE</a
